{
  "name": "ippon-web",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "pnpm gen-routes && tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "gen-routes": "tsr generate",
    "lint": "pnpm gen-routes && tsc --noEmit",
