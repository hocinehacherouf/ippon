# Copy this file to .env and adjust as needed. .env is gitignored.
# Defaults below are for LOCAL DEVELOPMENT ONLY — never deploy as-is.

# Host-side ports use a +10000 offset so ippon coexists with other local
# stacks running on the standard ports. Internal compose traffic still uses
# the defaults (e.g. workers connect to postgres:5432).

# ---- Postgres (OLTP: orgs, users, repos, scan_jobs, ...) -----------------
POSTGRES_USER=ippon
POSTGRES_PASSWORD=ippon-dev
POSTGRES_DB=ippon
POSTGRES_PORT=15432

# ---- ClickHouse (OLAP: sboms, dependencies, findings, vex_statements) ---
CLICKHOUSE_USER=ippon
CLICKHOUSE_PASSWORD=ippon-dev
CLICKHOUSE_DB=ippon
CLICKHOUSE_HTTP_PORT=18123
CLICKHOUSE_NATIVE_PORT=19000

# ---- Valkey (Celery broker + result backend + cache) --------------------
VALKEY_PORT=16379

# ---- RustFS (S3-compatible object store for CycloneDX blobs) ------------
# The official RustFS image refuses to start with default credentials.
RUSTFS_ACCESS_KEY=ippon-dev-access-key
RUSTFS_SECRET_KEY=ippon-dev-secret-key-please-change
# Host-side ports — internal traffic uses rustfs:9000 (not these)
RUSTFS_S3_PORT=9100
RUSTFS_CONSOLE_PORT=9101
RUSTFS_BUCKET=ippon-sboms

# ---- ippon API ----------------------------------------------------------
# Dev bearer token (replaced by real auth post-scaffold)
IPPON_DEV_TOKEN=dev-token-replace-me
# JobRunner backend: docker | k8s | inline
IPPON_JOB_RUNNER=docker
# Master key for envelope-encrypting source-provider credentials (PAT etc.)
IPPON_SECRET_KEY=insecure-dev-key-32-bytes-min-please-change

# ---- Connection URLs (used by API + workers; not by compose itself) -----
# Inside compose: hostnames are service names; outside (host shell): use localhost.
DATABASE_URL=postgresql+psycopg://ippon:ippon-dev@localhost:15432/ippon
CLICKHOUSE_URL=http://ippon:ippon-dev@localhost:18123/ippon
VALKEY_URL=redis://localhost:16379/0
S3_ENDPOINT_URL=http://localhost:9100
S3_BUCKET=ippon-sboms
