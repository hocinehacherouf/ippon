# Copy this file to .env and adjust as needed. .env is gitignored.
# Defaults below are for LOCAL DEVELOPMENT ONLY — never deploy as-is.
# Replace every ``changeme`` with a real value before exposing this stack
# beyond your workstation.

# Host-side ports use a +10000 offset so ippon coexists with other local
# stacks running on the standard ports. Internal compose traffic still uses
# the defaults (e.g. workers connect to postgres:5432).

# ---- Postgres (OLTP: orgs, users, repos, scan_jobs, ...) -----------------
# NB: the image is postgres:18. An existing data volume initialized by an
# older major (e.g. 16) will NOT boot on 18 — run `just nuke` to wipe local
# volumes (destroys local data) or pg_upgrade before bumping.
POSTGRES_USER=ippon
POSTGRES_PASSWORD=changeme
POSTGRES_DB=ippon
POSTGRES_PORT=15432

# ---- ClickHouse (OLAP: sboms, dependencies, findings, vex_statements) ---
CLICKHOUSE_USER=ippon
CLICKHOUSE_PASSWORD=changeme
CLICKHOUSE_DB=ippon
CLICKHOUSE_HTTP_PORT=18123
CLICKHOUSE_NATIVE_PORT=19000

# ---- Valkey (Celery broker + result backend + cache) --------------------
VALKEY_PORT=16379

# ---- ch-ui (ClickHouse admin UI; local dev only) ------------------------
# Browser at http://localhost:${CH_UI_PORT}; on first load supply
# URL=http://clickhouse:8123 and the CLICKHOUSE_* credentials above.
CH_UI_PORT=13488

# ---- RustFS (S3-compatible object store for CycloneDX blobs) ------------
# The official RustFS image refuses to start with default credentials.
RUSTFS_ACCESS_KEY=changeme
RUSTFS_SECRET_KEY=changeme
# Host-side ports — internal traffic uses rustfs:9000 (not these)
RUSTFS_S3_PORT=9100
RUSTFS_CONSOLE_PORT=9101
RUSTFS_BUCKET=ippon-sboms

# ---- ippon API ----------------------------------------------------------
# Dev bearer token (replaced by real auth post-scaffold)
IPPON_DEV_TOKEN=changeme
# JobRunner backend: docker | k8s | inline
IPPON_JOB_RUNNER=docker
# Master key encrypting source-connection credentials + webhook secrets.
IPPON_SECRET_KEY=changeme
# Externally-reachable API base, used to build the per-connection webhook
# URLs shown when you register a source (set this to your public hostname
# in a real deployment so providers can reach the webhook endpoint).
IPPON_PUBLIC_BASE_URL=http://localhost:8000

# ---- Connection URLs (used by API + workers; not by compose itself) -----
# Inside compose: hostnames are service names; outside (host shell): use localhost.
DATABASE_URL=postgresql+psycopg://ippon:changeme@localhost:15432/ippon
CLICKHOUSE_URL=http://ippon:changeme@localhost:18123/ippon
VALKEY_URL=redis://localhost:16379/0
S3_ENDPOINT_URL=http://localhost:9100
S3_BUCKET=ippon-sboms
